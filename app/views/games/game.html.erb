<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <title>Poker Clone</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Gabriela&display=swap" rel="stylesheet">
    <style>
      body {
        font-family: "Gabriela", sans-serif;
        font-weight: 400;
        font-style: normal;
      }
    </style>
    <%= stylesheet_link_tag 'game.css' %>
  </head>
  <body>
    <% if @in_lobby && !@is_player && !@is_admin %>
      <h3>Request to join game:</h3>
      <%= form_with url: "/player" do |form| %>
        <div>
          <%= form.label :player_name %>
          <%= form.text_field :name %>
          <input type="hidden" name="game_id" value="<%= @game.id %>">
          <%= form.submit "Submit" %>
        </div>
      <% end %>
    <% end %>

    <% if @is_admin %>
      <div id="admin-pannel">
        <%= render "admin" %>
      </div>
    <% end %>
      

    <div class="game-container" id="game-table">
      <%= render "game_board" %>
    </div>
  </body>
</html>

